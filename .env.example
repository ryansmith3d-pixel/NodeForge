# Copy this file to .env and add your key.
# Running tests requires no API key — the test suite runs entirely on stub handlers.
# Running the live pipeline requires a key. Use --mock to demo without one.
ANTHROPIC_API_KEY=your_key_here

# OpenAlex free API key — required by scripts/spikes/openalex_crispr/.
# Register at https://openalex.org/ to get one.
OPENALEX_API_KEY=your_openalex_key_here